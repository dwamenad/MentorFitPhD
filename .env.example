# The dev server runs on http://localhost:3000 by default.
# MentorFit can build its main discovery dataset from public academic APIs.
# `OPENALEX_EMAIL` is optional but recommended for OpenAlex's polite pool.
# `SEMANTIC_SCHOLAR_API_KEY` is optional and enables higher-rate Semantic Scholar enrichment.

APP_URL="http://localhost:3000"
OPENALEX_EMAIL=""
SEMANTIC_SCHOLAR_API_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
STRIPE_PRO_PRICE_LABEL="$19 / month"
